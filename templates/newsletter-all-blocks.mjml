<mjml lang="en">
	<mj-head>
		<mj-title></mj-title>
		<mj-preview></mj-preview>
		<mj-breakpoint width="639px"></mj-breakpoint>

		<mj-attributes>
			<!-- Global defaults -->
			<mj-all font-family="'Helvetica', 'Arial', sans-serif"></mj-all>
			<mj-section border="none" background-size="cover" background-repeat="no-repeat" background-position="center center"></mj-section>
			<mj-wrapper border="none"></mj-wrapper>
			<mj-column border="none" vertical-align="middle"></mj-column>
			<mj-text padding="0px" color="#2b2b2b"></mj-text>
			<mj-image padding="0" height="auto" align="center"></mj-image>
			<mj-spacer padding="0"></mj-spacer>
			<mj-button
				border-radius="0" border="none" padding="0"
				target="_blank" vertical-align="middle"
				inner-padding="20px 0px"
				font-size="10px" font-weight="700"
				text-transform="uppercase" letter-spacing="1.5px"
				line-height="100%"
				color="#ffffff" background-color="#009a4f"
				align="center"
			></mj-button>

			<!-- Text style classes -->
			<mj-class name="kicker" font-size="14px" font-weight="700" letter-spacing="9px" line-height="121%" text-transform="uppercase" padding-bottom="12px"></mj-class>
			<mj-class name="h1" font-size="50px" line-height="130%" padding-bottom="16px"></mj-class>
			<mj-class name="h2" font-size="45px" line-height="129%" padding-bottom="12px"></mj-class>
			<mj-class name="h3" font-size="35px" line-height="129%" padding-bottom="12px"></mj-class>
			<mj-class name="body-lg" font-size="25px" line-height="140%" padding-bottom="12px"></mj-class>
			<mj-class name="body" font-size="20px" line-height="140%"></mj-class>
			<mj-class name="footer" font-size="13px" line-height="185%" padding-bottom="8px" align="center" color="#000000"></mj-class>

			<!-- Modifier classes -->
			<mj-class name="white" color="#ffffff"></mj-class>
			<mj-class name="green" color="#009a4f"></mj-class>
			<mj-class name="centered" align="center"></mj-class>
			<mj-class name="black" color="#000000"></mj-class>
			<mj-class name="btn-light" background-color="#fffffe" color="#532a18"></mj-class>
		</mj-attributes>

		<mj-style>
			body {
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			p { margin: 0; }

			a[x-apple-data-detectors] {
				color: inherit !important;
				text-decoration: none !important;
			}

			#MessageViewBody a {
				color: inherit !important;
				text-decoration: none !important;
			}

			[x-apple-data-detectors-type="calendar-event"] {
				color: inherit !important;
				-webkit-text-decoration-color: inherit !important;
			}

			.link-green {
				font-weight: 700;
				color: #009a4f;
				text-decoration: none;
			}

			.link-inherit {
				color: inherit;
				text-decoration: none;
			}

			@media only screen and (max-width: 639px) {
				/* Responsive padding for background image sections */
				.hero-1 > div > table > tbody > tr > td { padding: 32px 16px 48px 16px !important; }
				.hero-2 > div > table > tbody > tr > td { padding: 48px 16px 48px 16px !important; }
				.hero-3 > div > table > tbody > tr > td { padding: 48px 16px 48px 16px !important; }
				.hero-4 > div > table > tbody > tr > td { padding: 16px 16px 140px 16px !important; }
				.hero-wrapper > table > tbody > tr > td,
				.hero-wrapper > div > table > tbody > tr > td { padding-top: 140px !important; padding-left: 16px !important; padding-right: 16px !important; }
				.text-h1, .text-h1 div, .text-h1 p, .text-h1 span, .text-h1 a { font-size: 32px !important; }
				.text-h2, .text-h2 div, .text-h2 p, .text-h2 span, .text-h2 a { font-size: 24px !important; }
				.text-h3, .text-h3 div, .text-h3 p, .text-h3 span, .text-h3 a { font-size: 20px !important; }
				.text-body-lg, .text-body-lg div, .text-body-lg p, .text-body-lg span, .text-body-lg a { font-size: 18px !important; }
				.text-body, .text-body div, .text-body p, .text-body span, .text-body a { font-size: 16px !important; }
				.text-kicker, .text-kicker div, .text-kicker p, .text-kicker span, .text-kicker a { font-size: 12px !important; letter-spacing: 4px !important; }

				/* Center-align on mobile for elements that are left-aligned on desktop */
				.mobile-center, .mobile-center div, .mobile-center p { text-align: center !important; }
				td.mobile-center { text-align: center !important; }
				td.mobile-center-btn > table { display: inline-block !important; }
				td.mobile-center-btn { text-align: center !important; }
			}
		</mj-style>

		<mj-raw>
			<meta name="format-detection" content="telephone=no, date=no, address=no, email=no, url=no">
			<meta name="x-apple-disable-message-reformatting">
			<meta name="color-scheme" content="light dark">
			<meta name="supported-color-schemes" content="light dark">

			<!--[if gte mso 9]>
			<style>
				a:link, span.MsoHyperlink {
					mso-style-priority: 99;
					color: inherit;
					text-decoration: none;
				}
				a:visited, span.MsoHyperlinkFollowed {
					mso-style-priority: 99;
					color: inherit;
					text-decoration: none;
				}
				li { margin-left: -1em !important }
				table, td, p, div, span, ul, ol, li, a, h1, h2, h3, h4, h5, h6 {
					mso-hyphenate: none;
				}
				sup, sub { font-size: 100% !important; }
				img { background-color: transparent !important; }
			</style>
			<![endif]-->
		</mj-raw>
	</mj-head>

	<mj-body background-color="#dbe8e4" width="640px">
		<mj-raw><!-- Note: #fffffe (not #ffffff) is used intentionally to prevent dark mode auto-inversion in some email clients --></mj-raw>

		<mj-raw><!-- Preheader logos --></mj-raw>
		<mj-section background-color="#ebebeb" padding="8px 16px 0px 16px">
			<mj-column width="608px">
				<mj-image alt="" src="https://prod.cdn.everyaction.com/images/van/EWG/EWG/1/71381/images/emailify/75f1a62ba9e0e0df84f68a18781f1345.png" width="73px"></mj-image>
			</mj-column>
		</mj-section>
		<mj-section background-color="#fffffe" padding="0px 16px 8px 16px">
			<mj-column width="608px">
				<mj-image alt="" src="https://prod.cdn.everyaction.com/images/van/EWG/EWG/1/71381/images/emailify/e7513ee7e84d8fd908432f35f1aad632.png" width="73px"></mj-image>
			</mj-column>
		</mj-section>

		<mj-raw><!-- Intro text + CTA --></mj-raw>
		<mj-section background-color="#fffffe" padding="32px" text-align="center">
			<mj-column background-color="#fffffe" vertical-align="top" width="576px">
				<mj-text mj-class="body centered" css-class="text-body" padding-bottom="32px">
					<p>{{FirstName or 'Friend'}},</p>
					<p>It&rsquo;s important to remember to look out for toxic pesticide residues. From apples to pears and kale to spinach, <span class="link-green">EWG's Shopper&rsquo;s Guide to Pesticides in Produce&TRADE;</span> found more than 75% of non-organic produce contains harmful pesticide residues, even after thorough washing!</p>
					<p>Shop smarter and avoid pesticides with EWG's Dirty Dozen&TRADE; list of fruits and vegetables. We recommend you buy organic when possible to reduce your exposure to toxic pesticides. Learn more below.</p>
				</mj-text>
				<mj-button href="https://www.ewg.org/?gad_campaignid=6443465025&gad_source=1&gbraid=0AAAAAD_iHo4qHj2NHItB6VYt0BJ31OV34&gclid=EAIaIQobChMIipeiroKEkwMVrk5HAR17Yx4mEAAYASAAEgIo9PD_BwE" width="161px">Learn More</mj-button>
			</mj-column>
		</mj-section>

		<mj-raw><!-- Card: image top, dark bg content --></mj-raw>
		<mj-wrapper background-color="#fffffe" padding="16px 0px" text-align="center">
			<mj-section background-color="#fffffe" padding="0">
				<mj-column width="640px" padding="0">
					<mj-image alt="" src="https://prod.cdn.everyaction.com/images/van/EWG/EWG/1/71381/images/emailify/35244751428adab0cfbde96c6e3421d8.jpg" width="640px"></mj-image>
				</mj-column>
			</mj-section>
			<mj-section background-color="#203a3b" padding="16px 20px">
				<mj-column padding="0px 0px 38px 0px" width="600px">
					<mj-spacer height="4px" padding-bottom="12px"></mj-spacer>
					<mj-text mj-class="kicker centered white" css-class="text-kicker">
						<p>Placeholder Kicker</p>
					</mj-text>
					<mj-text mj-class="h2 centered white" css-class="text-h2">
						<p>Placeholder H2</p>
